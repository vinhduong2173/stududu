# PostgreSQL (khớp docker-compose.yml ở repo root)
DATABASE_URL="postgresql://stududu:stududu@localhost:5432/stududu?schema=public"

# JWT — đổi secret trước khi deploy
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="30m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:3000"
